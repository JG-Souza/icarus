{
  "name": "jgsouza/icarus",
  "description": "A study package inspired by Laravel Breeze, focused on simplifying the implementation of basic authentication in Laravel projects, providing a lightweight and easy-to-customize structure.",
  "autoload": {
    "psr-4": {
      "Jgsouza\\Icarus\\": "src/"
    }
  },
  "authors": [
    {
      "name": "JG-Souza",
      "email": "joaogsouzafma@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2.0",
    "illuminate/console": "^11.0|^12.0",
    "illuminate/filesystem": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/validation": "^11.0|^12.0",
    "symfony/console": "^7.0"
  },
  "require-dev": {
    "laravel/framework": "^11.0|^12.0",
    "orchestra/testbench-core": "^9.0|^10.0",
    "phpstan/phpstan": "^2.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Jgsouza\\Icarus\\IcarusServiceProvider"
      ]
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/jg-souza/icarus"
    }
  ]
}
